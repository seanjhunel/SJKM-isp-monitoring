# ==========================================
# ISP MANAGEMENT SYSTEM CONFIGURATION
# ==========================================

# 1. MIKROTIK IP ADDRESS (CRITICAL)
# Make sure you put the ROUTER'S IP (Default Gateway)
# Do NOT put your own PC's IP here, or it will refuse to connect!
MIKROTIK_HOST=30.30.30.1

# 2. MIKROTIK API PORT
# Default API Port is 8728. Make sure this is Enabled in WinBox (IP > Services)
MIKROTIK_PORT=8728

# 3. WINBOX LOGIN
# Put your standard Winbox login details here:
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=p@ss2025